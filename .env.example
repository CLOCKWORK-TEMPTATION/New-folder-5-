# ============================================================
#  Multi-Agent Deep Research System — Unified Environment File
#  نسخ هذا الملف إلى .env وتعبئة القيم المطلوبة
#  cp .env.example .env
# ============================================================

# ────────────────────────────────────────────────────────────
#  1. مفاتيح نماذج الذكاء الاصطناعي (LLM API Keys)
# ────────────────────────────────────────────────────────────

# [مطلوب] — يستخدمه: search-manager, search-scout, content-extractor, deep-research
OPENAI_API_KEY=

# [مطلوب] — يستخدمه: search-scout, report-drafting
ANTHROPIC_API_KEY=

# ────────────────────────────────────────────────────────────
#  2. مفاتيح محركات البحث (واحد على الأقل مطلوب)
#     يستخدمها: search-scout-agent
# ────────────────────────────────────────────────────────────

# Serper.dev — استخدم مفتاح "dive deep search" من لوحة تحكم Serper
SERPER_API_KEY=

# Serper.dev — المفتاح الاحتياطي (Default key) — يُستخدم إذا فشل الأساسي
SERPER_API_KEY_FALLBACK=

# Tavily — بحث مُحسَّن للذكاء الاصطناعي
TAVILY_API_KEY=

# Bing Web Search API v7 (Azure Cognitive Services)
# المفتاح من: Azure Portal → Bing Search v7 resource → Keys
BING_SEARCH_API_KEY=

# ────────────────────────────────────────────────────────────
#  3. إعدادات النماذج (Models Configuration)
# ────────────────────────────────────────────────────────────

# النموذج الافتراضي للمنسق (search-manager-agent)
MODEL_NAME=gpt-4o

# النموذج الافتراضي لوكيل الاستخراج (content-extractor-agent)
OPENAI_MODEL=gpt-4o-mini

# درجة حرارة النماذج (0 = حتمي، 1 = إبداعي)
OPENAI_TEMPERATURE=0

# مزوّد النموذج الافتراضي لوكيل البحث: "anthropic" أو "openai"
DEFAULT_MODEL_PROVIDER=anthropic

# ────────────────────────────────────────────────────────────
#  4. نماذج متقدمة لوكيل التحليل (deep-research-analysis-agent)
#     اتركها فارغة لاستخدام OPENAI_MODEL كافتراضي للجميع
# ────────────────────────────────────────────────────────────

OPENAI_COORDINATOR_MODEL=
OPENAI_RESEARCH_MODEL=
OPENAI_VERIFIER_MODEL=
OPENAI_EXTRACTOR_MODEL=
OPENAI_DETECTOR_MODEL=
OPENAI_COORDINATOR_TEMPERATURE=0
OPENAI_SUBAGENT_TEMPERATURE=0

# ────────────────────────────────────────────────────────────
#  5. إعدادات المهلة الزمنية (Timeouts)
# ────────────────────────────────────────────────────────────

# مهلة محركات البحث بالميلي ثانية (search-scout-agent)
SEARCH_TIMEOUT_MS=15000

# مهلة المتصفح الآلي بالميلي ثانية (content-extractor-agent / Puppeteer)
HEADLESS_BROWSER_TIMEOUT_MS=30000

# ────────────────────────────────────────────────────────────
#  6. التتبع والمراقبة (Observability) — اختياري
#     يستخدمها: deep-research-analysis-agent
# ────────────────────────────────────────────────────────────

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-research-analysis-agent
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true

# ────────────────────────────────────────────────────────────
#  7. إعدادات متنوعة
# ────────────────────────────────────────────────────────────

# User-Agent string لطلبات الويب (deep-research-analysis-agent)
DEEP_AGENT_USER_AGENT=deep-research-analysis-agent/0.1

# وكيل البحث: الحد الأقصى للنتائج لكل استعلام
DEFAULT_MAX_RESULTS=10

# وكيل البحث: نوع التخزين المؤقت (state | store | filesystem)
BACKEND_TYPE=state

# وكيل البحث: مجلد العمل
WORKSPACE_DIR=./search-workspace

# وكيل البحث: تفعيل الحفظ المستمر
ENABLE_PERSISTENCE=false
