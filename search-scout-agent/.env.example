# ─────────────────────────────────────────────
# مزودي نماذج اللغة (LLM Providers)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# محركات البحث (Search Engines)
# ─────────────────────────────────────────────
SERPER_API_KEY=your-serper-api-key
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_SEARCH_ENGINE_ID=your-google-cse-id
BING_SEARCH_API_KEY=your-bing-api-key
TAVILY_API_KEY=tvly-...

# ─────────────────────────────────────────────
# إعدادات عامة (General Settings)
# ─────────────────────────────────────────────
DEFAULT_MODEL_PROVIDER=anthropic
DEFAULT_MAX_RESULTS=10
SEARCH_TIMEOUT_MS=15000

# ─────────────────────────────────────────────
# Backend و Persistence (من التوثيق الرسمي)
# ─────────────────────────────────────────────
# نوع Backend: state | store | filesystem | local-shell
BACKEND_TYPE=state
# مجلد العمل (لـ filesystem و local-shell فقط)
WORKSPACE_DIR=./search-workspace
# تفعيل الحفظ الدائم (checkpointer + store)
ENABLE_PERSISTENCE=false
